{
  "name": "standup-bot",
  "version": "1.0.0",
  "description": "Smart Daily Standup Bot - Automates Agile standups via Slack, Jira, and Google Calendar",
  "main": "dist/functions.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "test:coverage": "jest --coverage",
    "deploy": "npm run build && firebase deploy --only functions",
    "serve": "npm run build && firebase emulators:start --only functions"
  },
  "keywords": [
    "slack",
    "jira",
    "standup",
    "agile"
  ],
  "author": "chrisp",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "firebase-tools": "^15.10.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@slack/web-api": "^7.14.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.1.1",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1"
  }
}
